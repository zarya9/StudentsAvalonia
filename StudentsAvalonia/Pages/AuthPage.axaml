<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="StudentsAvalonia.AuthPage"
        Title="AuthPage">
    <Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition Width="*"/>
            <ColumnDefinition Width="400"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
			<RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Column="1" Grid.Row="1">
		    <TextBlock Text="Добро пожаловать!"/>
            <TextBlock Text="Логин"/>
            <TextBox x:Name="TxtLogin"  />
            <TextBlock Text="Пароль"/>
            <TextBox x:Name="TxtPassword"  />

            <Button Content="Авторизоваться" HorizontalAlignment="Center" Click="Button_Click" Margin="0 20 0 0"/>
            <TextBlock x:Name="TxtError"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Grid.Row="2" HorizontalAlignment="Center">
			<TextBlock Text="Нет аккаунта? Зарегистрируйся" PointerPressed="TextBlock_PointerPressed"/>
        </StackPanel>
    </Grid>
    
</Window>
